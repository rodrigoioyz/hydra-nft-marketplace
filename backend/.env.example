# ── Hydra node ────────────────────────────────────────────────────────────────
HYDRA_WS_URL=ws://127.0.0.1:4001
HYDRA_HTTP_URL=http://127.0.0.1:4001

# ── Blockfrost (preprod) ───────────────────────────────────────────────────────
# Get a free key at https://blockfrost.io → New Project → select "Cardano preprod"
BLOCKFROST_PROJECT_ID=preprodYOUR_KEY_HERE
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://marketplace:marketplace@127.0.0.1:5432/marketplace

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Cardano CLI + operator signing key ────────────────────────────────────────
# Absolute path to the cardano-cli binary
CARDANO_CLI_PATH=/path/to/cardano-cli
# Path to the operator Cardano payment signing key — NEVER commit the real .skey
SKEY_PATH=/path/to/hydra/keys/cardano.skey
TESTNET_MAGIC=1
CARDANO_NODE_SOCKET_PATH=/path/to/cardano_preprod/sockets/node.socket
# Operator bech32 address (derived from cardano.vkey — see README §Keys)
OPERATOR_ADDRESS=addr_test1...

# ── Listing validator ─────────────────────────────────────────────────────────
# Script address derived from the compiled contract (see README §Contract)
SCRIPT_ADDRESS=addr_test1...
# Double-CBOR encoded compiledCode from contracts/plutus.json
# Run the helper: node scripts/encode-script.js  (or see README §Contract for manual steps)
SCRIPT_CBOR=59...

# ── Protocol parameters file (used by cardano-cli for Plutus script txs) ──────
PROTOCOL_PARAMS_PATH=/path/to/hydra/keys/protocol-parameters.json

# ── Transaction fee (lovelace) ────────────────────────────────────────────────
# Hydra uses L1 fee formula: txFeeFixed=155381 + txFeePerByte=44
# 600000 covers script-spending txs (~437 bytes); increase if you see FeeTooSmall
TX_FEE=600000
