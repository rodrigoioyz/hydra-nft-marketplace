# Hydra node
HYDRA_WS_URL=ws://127.0.0.1:4001
HYDRA_HTTP_URL=http://127.0.0.1:4001

# Blockfrost (preprod) — get your key at https://blockfrost.io
BLOCKFROST_PROJECT_ID=preprodYOUR_KEY_HERE
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0

# Database (PostgreSQL)
DATABASE_URL=postgresql://marketplace:marketplace@127.0.0.1:5432/marketplace

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Cardano CLI — absolute path inside WSL
CARDANO_CLI_PATH=/path/to/cardano-cli
SKEY_PATH=/path/to/operator.skey
TESTNET_MAGIC=1

# Listing validator — compiled from contracts/plutus.json (run: cd contracts && aiken build)
SCRIPT_ADDRESS=addr_test1...
SCRIPT_CBOR=<hex from plutus.json compiledCode>

# Fee for inside-Head txs (0 = zero-fee protocol params; set to 165633 if using standard params)
TX_FEE=0
