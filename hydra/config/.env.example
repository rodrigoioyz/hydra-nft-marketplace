# Hydra NFT Marketplace — Hydra Node Configuration
# Network: Cardano preprod
# Hydra version: 1.2.0

# ── Binaries ────────────────────────────────────────────────────────────────
HYDRA_BIN=/path/to/hydra-node
HYDRA_TUI=/path/to/hydra-tui
CARDANO_CLI=/path/to/cardano-cli

# ── Cardano node ────────────────────────────────────────────────────────────
NODE_SOCKET=/path/to/cardano-node/sockets/node.socket
TESTNET_MAGIC=1

# ── Blockfrost ───────────────────────────────────────────────────────────────
BLOCKFROST_PROJECT_ID=preprodYOUR_KEY_HERE
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0

# ── Keys ────────────────────────────────────────────────────────────────────
MARKETPLACE_DIR=/path/to/hydra-nft-marketplace
KEYS_DIR=${MARKETPLACE_DIR}/hydra/keys
HYDRA_SK=${KEYS_DIR}/hydra.sk
HYDRA_VK=${KEYS_DIR}/hydra.vk
CARDANO_SKEY=${KEYS_DIR}/cardano.skey
CARDANO_VKEY=${KEYS_DIR}/cardano.vkey
CARDANO_ADDR_FILE=${KEYS_DIR}/cardano.addr
PROTOCOL_PARAMS=${MARKETPLACE_DIR}/hydra/config/protocol-parameters-zero-fees.json

# ── Head parameters ──────────────────────────────────────────────────────────
NODE_ID=marketplace-1
API_HOST=127.0.0.1
API_PORT=4001
CONTESTATION_PERIOD_SECS=180   # 3 min for preprod; use 43200 (12h) for mainnet

# ── Persistence ──────────────────────────────────────────────────────────────
PERSISTENCE_DIR=${MARKETPLACE_DIR}/hydra/data
LOGS_DIR=${MARKETPLACE_DIR}/hydra/logs
